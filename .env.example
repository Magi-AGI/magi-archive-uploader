# S3 archive target
ARCHIVE_BUCKET=magi-archive-session-archives-376018611447-us-west-1-an
AWS_REGION=us-west-1

# Source paths (absolute)
FOUNDRY_VIDEO_PATH=/home/ubuntu/magi-assistant-foundry/data/video
DISCORD_SESSIONS_PATH=/home/ubuntu/magi-assistant-discord/data/sessions
MATTERMOST_EXPORTS_PATH=/home/ubuntu/mattermost_exports

# Ledger location (SQLite)
LEDGER_PATH=/home/ubuntu/.local/share/magi-archive-uploader/ledger.sqlite

# Per-source retention (days local file is kept after S3-verified upload)
# 0 or unset = keep forever (cleanup pass skips this source)
FOUNDRY_VIDEO_RETENTION_DAYS=7
DISCORD_SESSIONS_RETENTION_DAYS=7
MATTERMOST_EXPORTS_RETENTION_DAYS=

# Stability window: skip files whose mtime is younger than this (seconds).
# Heuristic for "file is still being written".
STABILITY_WINDOW_SECONDS=300

# Multipart threshold (bytes). Files larger than this use multipart upload.
MULTIPART_THRESHOLD=104857600

# Optional: set LOG_LEVEL=debug for verbose output
LOG_LEVEL=info
